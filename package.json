{
  "name": "@kalabamssalu/rich-text-editor",
  "version": "0.3.0",
  "description": "Lexical rich text editor for React with configurable mentions, templates, and tools",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/KalabAmssalu/rich-text-editor.git"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./box": {
      "types": "./dist/box.d.ts",
      "import": "./dist/box.js",
      "require": "./dist/box.cjs"
    },
    "./styles.css": "./dist/styles.css"
  },
  "sideEffects": [
    "**/*.css"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "dev": "tsup --watch",
    "prepublishOnly": "pnpm run build"
  },
  "peerDependencies": {
    "@lexical/code": "^0.44.0",
    "@lexical/extension": "^0.44.0",
    "@lexical/file": "^0.44.0",
    "@lexical/hashtag": "^0.44.0",
    "@lexical/html": "^0.44.0",
    "@lexical/link": "^0.44.0",
    "@lexical/list": "^0.44.0",
    "@lexical/markdown": "^0.44.0",
    "@lexical/overflow": "^0.44.0",
    "@lexical/react": "^0.44.0",
    "@lexical/rich-text": "^0.44.0",
    "@lexical/selection": "^0.44.0",
    "@lexical/table": "^0.44.0",
    "@lexical/text": "^0.44.0",
    "@lexical/utils": "^0.44.0",
    "lexical": "^0.44.0",
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0",
    "sonner": "^1.7.0"
  },
  "peerDependenciesMeta": {
    "sonner": {
      "optional": true
    }
  },
  "dependencies": {
    "@lexical/code-prism": "^0.44.0",
    "@lexical/code-shiki": "^0.44.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "1.1.1",
    "date-fns": "4.1.0",
    "lucide-react": "^0.564.0",
    "mammoth": "^1.12.0",
    "radix-ui": "^1.4.3",
    "react-day-picker": "^9.7.0",
    "sonner": "^1.7.1",
    "tailwind-merge": "^3.3.1"
  },
  "devDependencies": {
    "@lexical/code": "^0.44.0",
    "@lexical/extension": "^0.44.0",
    "@lexical/file": "^0.44.0",
    "@lexical/hashtag": "^0.44.0",
    "@lexical/html": "^0.44.0",
    "@lexical/link": "^0.44.0",
    "@lexical/list": "^0.44.0",
    "@lexical/markdown": "^0.44.0",
    "@lexical/overflow": "^0.44.0",
    "@lexical/react": "^0.44.0",
    "@lexical/rich-text": "^0.44.0",
    "@lexical/selection": "^0.44.0",
    "@lexical/table": "^0.44.0",
    "@lexical/text": "^0.44.0",
    "@lexical/utils": "^0.44.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "jsdom": "^29.1.1",
    "lexical": "^0.44.0",
    "react": "^19",
    "react-dom": "^19",
    "tsup": "^8.4.0",
    "typescript": "5.7.3",
    "vitest": "^4.1.6"
  }
}
